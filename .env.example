# ============================================================
# n8n Workflow Builder — Environment Configuration
# ============================================================
# Non modificare questo file direttamente — lancia ./setup.sh
# ============================================================

# --- Google Gemini API Key ---
# Da: https://aistudio.google.com/apikey
GOOGLE_KEY=your-gemini-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# --- n8n Connection ---
N8N_HOST_URL=http://host.docker.internal:5678
N8N_API_KEY=your-n8n-api-key-here

# --- LibreChat ---
LIBRECHAT_PORT=3080
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# --- LibreChat Auth Secrets ---
# Generati automaticamente da setup.sh (openssl rand)
JWT_SECRET=changeme-jwt-secret
JWT_REFRESH_SECRET=changeme-jwt-refresh-secret
CREDS_KEY=changeme-creds-key-32chars-hex
CREDS_IV=changeme-creds-iv-16chars-hex

# --- MongoDB ---
MONGO_URI=mongodb://mongodb:27017/LibreChat

# --- Meilisearch ---
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=changeme-meili-key

# --- n8n (solo se installato dal compose) ---
N8N_PORT=5678
GENERIC_TIMEZONE=Europe/Paris
